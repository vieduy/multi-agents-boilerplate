# ============================================
# Multi-Agent System Environment Variables
# ============================================
# Copy this file to .env and configure your values

# ============================================
# API Keys & Credentials
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# Encoder Configuration
# ============================================
ENCODER_PROVIDER=openai
ENCODER_MODEL=text-embedding-3-small
ENCODER_BASE_URL=
ENCODER_API_KEY=${OPENAI_API_KEY}

# ============================================
# LLM Configuration
# ============================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=${OPENAI_API_KEY}
LLM_TEMPERATURE=0.1
LLM_BASE_URL=
ENABLE_LLM_FALLBACK=true
LLM_FALLBACK_THRESHOLD=0.6
MAX_LLM_FALLBACK_PER_MINUTE=100
CACHE_LLM_DECISIONS=true

# ============================================
# Router Configuration
# ============================================
ROUTER_THRESHOLD=0.6
ROUTER_AUTO_SYNC=local
ROUTER_CACHE_ENABLED=true
ROUTER_FALLBACK_ROUTE=general-chatbot

# ============================================
# Service Ports
# ============================================
FRONTEND_PORT=3000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ============================================
# Authentication & Security
# ============================================
# IMPORTANT: Change these secrets in production!
AUTH_ENABLED=false
JWT_SECRET_KEY=change-this-secret-key-in-production-min-32-chars-long
AUTH_JWT_SECRET_KEY=change-this-secret-key-in-production-min-32-chars-long
AUTH_JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_MIN_LENGTH=8
REQUIRE_EMAIL_VERIFICATION=false

# Auth Service Configuration
AUTH_USE_REMOTE_VERIFICATION=false

# API Security
API_KEY_REQUIRED=false
RATE_LIMIT_PER_MINUTE=1000

# ============================================
# Secrets Manager
# ============================================
SECRETS_MANAGER_API_KEY=your-secrets-manager-api-key-here
SECRETS_ENCRYPTION_KEY=your-32-char-encryption-key-here

# ============================================
# MongoDB Configuration
# ============================================
MONGO_ENABLED=true
MONGO_DATABASE=agent_router
MONGO_COLLECTION=conversation_messages

# ============================================
# Redis Cache Configuration
# ============================================
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.95
SEMANTIC_CACHE_MAX_SIZE=1000

# ============================================
# Logging & Monitoring
# ============================================
LOG_LEVEL=INFO
ENABLE_METRICS=true

# ============================================
# Deployment Configuration
# ============================================
DEPLOY_MULTI_AGENT_CONFIG_PATH=

# ============================================
# Development Settings (for docker-compose.dev.yml)
# ============================================
# Uncomment these for local development with exposed ports
# MONGO_PORT=27117
# REDIS_PORT=6479
# AGENT_ROUTER_PORT=8000
# AUTH_SERVICE_PORT=8001
# SECRETS_MANAGER_PORT=8092
# TOOL_EXECUTOR_PORT=8090
